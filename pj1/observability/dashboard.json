  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Latency (Seconds)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(http_request_duration_seconds_sum[5m]) / rate(http_request_duration_seconds_count[5m])" }]
    },
    {
      "title": "Traffic (RPS)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(http_requests_total[5m]))" }]
    },
    {
      "title": "Errors (5xx Rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m]))" }]
    },
    {
      "title": "Saturation (CPU Usage)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(node_namespace_pod_container:container_cpu_usage_seconds_total:sum_irate)" }]
    }
  ],
  "title": "Production SRE - Four Golden Signals",
  "version": 1
}
